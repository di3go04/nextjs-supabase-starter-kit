# =====================================================
#  Environment Variables Template
#  Copia a `.env.local` y reemplaza con tus credenciales.
#  NUNCA commitear .env.local — ya está en .gitignore.
# =====================================================

# -----------------------------------------------------
#  Supabase
#  Dashboard: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# -----------------------------------------------------
#  Stripe
#  Dashboard: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Crea 2 productos en Stripe y pega aquí sus price_id:
STRIPE_PRICE_ID_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID

# -----------------------------------------------------
#  Resend
#  Dashboard: https://resend.com/api-keys
# -----------------------------------------------------
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=onboarding@your-domain.com

# -----------------------------------------------------
#  App
# -----------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_DEFAULT_LOCALE=es

# -----------------------------------------------------
#  Opcionales (analytics, observabilidad, rate limiting)
# -----------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_YOUR_POSTHOG_KEY
# NEXT_PUBLIC_SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT
# UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
# EDGE_CONFIG=ec_YOUR_EDGE_CONFIG_ID
